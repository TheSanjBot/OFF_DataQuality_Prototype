      "perl_logic": "# RULE_NAME: ca_contains_statement_without_allergen_evidence\n# SEVERITY: warning\n# COMPLEXITY: medium\n# DECLARATIVE_FRIENDLY: yes\nif (($contains_statement_present > 0) && ($allergen_evidence_present == 0)) {\n    push @{$product_ref->{$data_quality_tags}}, \"ca-contains-statement-without-allergen-evidence\";\n}",
      "python_conversion": "def check_ca_contains_statement_without_allergen_evidence(product: dict):\n    \"\"\"\n    Returns the tag 'ca-contains-statement-without-allergen-evidence' if the product violates the rule:\n    contains_statement_present > 0.0 AND allergen_evidence_present == 0.0.\n    Returns None otherwise, including when required fields are missing or non-numeric.\n    \"\"\"\n    tag = \"ca-contains-statement-without-allergen-evidence\"\n\n    # Retrieve fields\n    contains_val = product.get(\"contains_statement_present\")\n    allergen_val = product.get(\"allergen_evidence_present\")\n\n    # Validate presence and numeric type\n    for val in (contains_val, allergen_val):\n        if val is None:\n            return None\n        if not isinstance(val, (int, float)):\n            return None\n        # Exclude NaN values\n        try:\n            import math\n            if math.isnan(val):\n                return None\n        except Exception:\n            pass\n\n    # Apply compound condition\n    if contains_val > 0.0 and allergen_val == 0.0:\n        return tag\n    return None",
      "conversion_notes": "Converted via Groq (openai/gpt-oss-120b).",
      "conversion_provider": "groq"
    },
